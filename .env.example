# Anthropic Claude API key — get from https://console.anthropic.com/
# Free trial credits (~$5) on signup. ~$4-6/month at daily use.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API key — get from https://aistudio.google.com/app/apikey
# 100% FREE: 1500 requests/day, 15 requests/minute (no billing required)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase PostgreSQL — Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
